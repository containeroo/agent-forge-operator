FROM --platform=${BUILDPLATFORM} debian:bookworm-slim AS govc
ARG TARGETARCH
ARG GOVC_VERSION=v0.53.1

RUN set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends ca-certificates curl; \
    rm -rf /var/lib/apt/lists/*; \
    case "${TARGETARCH}" in \
      amd64) govc_arch="x86_64" ;; \
      arm64) govc_arch="arm64" ;; \
      *) echo "unsupported govc architecture: ${TARGETARCH}" >&2; exit 1 ;; \
    esac; \
    curl -fsSL "https://github.com/vmware/govmomi/releases/download/${GOVC_VERSION}/govc_Linux_${govc_arch}.tar.gz" \
      | tar -xz -C /tmp govc

FROM gcr.io/distroless/static:nonroot
WORKDIR /
COPY manager .
COPY --from=govc /tmp/govc /usr/local/bin/govc
USER 65532:65532

ENTRYPOINT ["/manager"]
